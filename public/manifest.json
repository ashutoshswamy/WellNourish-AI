{
  "name": "WellNourish AI - Personal Diet & Workout Planner",
  "short_name": "WellNourish AI",
  "description": "Transform your health with WellNourish AI - the smartest personal diet and workout planner powered by artificial intelligence.",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#ffffff",
  "theme_color": "#16a34a",
  "orientation": "portrait-primary",
  "scope": "/",
  "prefer_related_applications": false,
  "id": "wellnourish-ai-app",
  "icons": [
    {
      "src": "/android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/apple-touch-icon.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "categories": ["health", "fitness", "lifestyle", "medical", "wellness"],
  "lang": "en",
  "dir": "ltr",
  "shortcuts": [
    {
      "name": "Create New Plan",
      "short_name": "New Plan",
      "description": "Create a new personalized diet and workout plan",
      "url": "/",
      "icons": [
        {
          "src": "/android-chrome-192x192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "View Plans",
      "short_name": "Plans",
      "description": "View all your wellness plans",
      "url": "/plans",
      "icons": [
        {
          "src": "/android-chrome-192x192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+wellnourish",
      "url": "/?protocol=%s"
    }
  ]
}
